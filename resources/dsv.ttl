<https://example.com/cztkv/#> a prof:Profile, dsv:ApplicationProfile.
:Teacher dct:isPartOf <https://example.com/cztkv/#>;
    a dsv:TermProfile;
    dsv:reusesPropertyValue [
  a dsv:PropertyValueReuse;
  dsv:reusedProperty skos:prefLabel;
  dsv:reusedFromResource <https://example.org/vocab/Teacher>
], [
  a dsv:PropertyValueReuse;
  dsv:reusedProperty skos:definition;
  dsv:reusedFromResource <https://example.org/vocab/Teacher>
];
    a dsv:ClassProfile;
    dsv:class <https://example.org/vocab/Teacher>.
:Course dct:isPartOf <https://example.com/cztkv/#>;

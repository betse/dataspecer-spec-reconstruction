<https://example.com/cztkv/#Teacher.teachername> dct:isPartOf <https://example.com/cztkv/#>;
    a dsv:TermProfile;
    skos:prefLabel "Teacher name"@en;
    dsv:reusesPropertyValue [
  a dsv:PropertyValueReuse;
  dsv:reusedProperty skos:definition;
  dsv:reusedFromResource <https://example.org/vocab/teacherName>
];
    dsv:cardinality cardinality:11;
    dsv:property <https://example.org/vocab/teacherName>;
    dsv:domain :Teacher;
    dsv:requirementLevel requirement:mandatory;
    a dsv:DatatypePropertyProfile;
    dsv:datatypePropertyRange rdfs:Literal.


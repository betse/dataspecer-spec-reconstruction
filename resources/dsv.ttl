<https://example.com/cztkv/#Course.taughtby> dct:isPartOf <https://example.com/cztkv/#>;
    a dsv:TermProfile;
    dsv:reusesPropertyValue [
  a dsv:PropertyValueReuse;
  dsv:reusedProperty skos:prefLabel;
  dsv:reusedFromResource <https://example.com/vocabulary#taughtBy>
